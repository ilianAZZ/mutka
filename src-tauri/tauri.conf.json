{
  "productName": "Mutka",
  "version": "0.1.0",
  "identifier": "app.mutka",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Mutka",
        "width": 1100,
        "height": 700,
        "minWidth": 620,
        "minHeight": 420,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true,
        "transparent": true,
        "devtools": true,
        "dragDropEnabled": false
      }
    ],
    "security": {
      "csp": null
    },
    "withGlobalTauri": true
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Utility",
    "shortDescription": "Community-driven modular file explorer for macOS",
    "longDescription": "Mutka is a fast, macOS file explorer built on a community-first modular architecture. Every feature — copy/paste, navigation, file operations — is a swappable module. Built with Tauri 2 and React 18.",
    "copyright": "© 2026 Mutka contributors",
    "macOS": {
      "minimumSystemVersion": "10.14"
    }
  }
}
